# ── Water Savers — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
#
# LOCAL DEV:  hanya isi DATABASE_URL + GROQ_API_KEY
# PRODUCTION (Render): isi semua kecuali DATABASE_URL bisa kosong/file:dummy

# ── Database ──────────────────────────────────────────────────────────────
# Local dev (SQLite):        file:./db/custom.db
# Production (Turso):        file:./dummy.db  (tidak dipakai, tapi wajib ada)
DATABASE_URL=file:./db/custom.db

# Turso (production only — set di Render Environment Variables)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

# ── Groq API (required for AquAI chat, vision, web search) ───────────────
# Dapat dari: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Next.js ──────────────────────────────────────────────────────────────
# Production: set ke "production" di Render
# NODE_ENV=production

# ── Auth (optional — if using NextAuth) ──────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_random_secret_here
